# Local Worker secrets for `wrangler dev`. Copy to `worker/.dev.vars` (gitignored)
# and fill in real values. Do NOT commit the real .dev.vars file.

# Liveblocks project secret key (Dashboard → project → API keys). Never shipped to the client.
LIVEBLOCKS_SECRET_KEY=sk_dev_replace_me

# Local bypass identity for wrangler dev. Never set this in production.
DEV_AUTH_EMAIL=me@example.com

# Production Access validation vars. Optional locally when DEV_AUTH_EMAIL is set.
# ACCESS_TEAM_DOMAIN=https://<team>.cloudflareaccess.com
# ACCESS_AUD=<access-aud>

# Optional: lock CORS to your Pages origin in production (e.g. https://travel-planner.pages.dev).
# Leave unset locally to reflect the request Origin.
# ALLOWED_ORIGIN=
